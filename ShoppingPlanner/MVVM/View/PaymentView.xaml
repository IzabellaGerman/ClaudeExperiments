<UserControl x:Class="ShoppingPlanner.MVVM.View.PaymentView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="10">
            <TextBlock Text="Payment Information"
                       Foreground="White"
                       FontSize="22"
                       FontWeight="Bold"
                       Margin="0,0,0,5"/>
            <TextBlock Text="Enter card details for automatic payment"
                       Foreground="#CFCFCF"
                       FontSize="13"
                       Margin="0,0,0,20"/>

            <Border Background="#22202f" CornerRadius="10" Padding="25"
                    Width="480" HorizontalAlignment="Left">
                <StackPanel>
                    <TextBlock Text="Cardholder Name" Foreground="#CFCFCF" FontSize="12" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding CardholderName, UpdateSourceTrigger=PropertyChanged}"
                             Background="#353540" Foreground="White" FontSize="13"
                             Padding="10,8" BorderThickness="0" Margin="0,0,0,15"/>

                    <TextBlock Text="Card Number" Foreground="#CFCFCF" FontSize="12" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding CardNumber, UpdateSourceTrigger=PropertyChanged}"
                             Background="#353540" Foreground="White" FontSize="13"
                             Padding="10,8" BorderThickness="0" MaxLength="19" Margin="0,0,0,15"/>

                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="120"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Expiry Date (MM/YY)" Foreground="#CFCFCF" FontSize="12" Margin="0,0,0,5"/>
                            <TextBox Text="{Binding ExpiryDate, UpdateSourceTrigger=PropertyChanged}"
                                     Background="#353540" Foreground="White" FontSize="13"
                                     Padding="10,8" BorderThickness="0" MaxLength="5"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="CVV" Foreground="#CFCFCF" FontSize="12" Margin="0,0,0,5"/>
                            <TextBox Text="{Binding CVV, UpdateSourceTrigger=PropertyChanged}"
                                     Background="#353540" Foreground="White" FontSize="13"
                                     Padding="10,8" BorderThickness="0" MaxLength="4"/>
                        </StackPanel>
                    </Grid>

                    <CheckBox Content="Enable automatic payment"
                              IsChecked="{Binding AutoPaymentEnabled}"
                              Foreground="White"
                              FontSize="13"
                              Margin="0,5,0,0"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
