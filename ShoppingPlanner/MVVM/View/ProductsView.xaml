<UserControl x:Class="ShoppingPlanner.MVVM.View.ProductsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Product List"
                   Foreground="White"
                   FontSize="22"
                   FontWeight="Bold"
                   Margin="10,10,10,5"/>
        <TextBlock Grid.Row="1"
                   Text="Add products you buy regularly"
                   Foreground="#CFCFCF"
                   FontSize="13"
                   Margin="10,0,10,15"/>

        <!-- Add product form -->
        <Border Grid.Row="2"
                Background="#22202f"
                CornerRadius="10"
                Padding="18"
                Margin="10,0,10,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="70"/>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Column="0" Text="Product Name" Foreground="#CFCFCF" FontSize="11" Margin="0,0,8,4"/>
                <TextBlock Grid.Column="1" Text="Store" Foreground="#CFCFCF" FontSize="11" Margin="0,0,8,4"/>
                <TextBlock Grid.Column="2" Text="Qty" Foreground="#CFCFCF" FontSize="11" Margin="0,0,8,4"/>
                <TextBlock Grid.Column="3" Text="Frequency" Foreground="#CFCFCF" FontSize="11" Margin="0,0,8,4"/>

                <TextBox Grid.Row="1" Grid.Column="0"
                         Text="{Binding NewProductName, UpdateSourceTrigger=PropertyChanged}"
                         Background="#353540" Foreground="White" FontSize="13"
                         Padding="8,6" BorderThickness="0" Margin="0,0,8,0"/>

                <ComboBox Grid.Row="1" Grid.Column="1"
                          ItemsSource="{Binding SelectedStoreNames}"
                          SelectedItem="{Binding NewProductStore}"
                          FontSize="13" Padding="4" Margin="0,0,8,0"/>

                <TextBox Grid.Row="1" Grid.Column="2"
                         Text="{Binding NewProductQty, UpdateSourceTrigger=PropertyChanged}"
                         Background="#353540" Foreground="White" FontSize="13"
                         Padding="8,6" BorderThickness="0" Margin="0,0,8,0"/>

                <ComboBox Grid.Row="1" Grid.Column="3"
                          ItemsSource="{Binding FrequencyOptions}"
                          SelectedItem="{Binding NewProductFrequency}"
                          FontSize="13" Padding="4" Margin="0,0,8,0"/>

                <Button Grid.Row="1" Grid.Column="4"
                        Content="  Add  "
                        Command="{Binding AddProductCommand}"
                        Padding="14,6"
                        FontSize="13" FontWeight="SemiBold"
                        Foreground="White" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="#27AE60" CornerRadius="5" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#219A52"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>

        <!-- Product list -->
        <Border Grid.Row="3"
                Background="#22202f"
                CornerRadius="10"
                Margin="10,0,10,10"
                Padding="5">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <DataGrid ItemsSource="{Binding Products}"
                          SelectedItem="{Binding SelectedProduct}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          HeadersVisibility="Column"
                          GridLinesVisibility="None"
                          BorderThickness="0"
                          FontSize="13"
                          Background="Transparent"
                          RowBackground="#22202f"
                          AlternatingRowBackground="#2a2840"
                          Foreground="White">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#353540"/>
                            <Setter Property="Foreground" Value="#CFCFCF"/>
                            <Setter Property="Padding" Value="10,8"/>
                            <Setter Property="FontSize" Value="12"/>
                            <Setter Property="BorderThickness" Value="0"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="Padding" Value="10,6"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#3a3850"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.CellStyle>
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#3a3850"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Product" Binding="{Binding Name}" Width="*"/>
                        <DataGridTextColumn Header="Store" Binding="{Binding Store}" Width="140"/>
                        <DataGridTextColumn Header="Qty" Binding="{Binding Quantity}" Width="60"/>
                        <DataGridTextColumn Header="Frequency" Binding="{Binding Frequency}" Width="130"/>
                    </DataGrid.Columns>
                </DataGrid>

                <Button Grid.Row="1"
                        Content="  Remove Selected  "
                        Command="{Binding RemoveProductCommand}"
                        HorizontalAlignment="Right"
                        Margin="0,10,5,5"
                        Padding="14,6"
                        FontSize="12"
                        Foreground="White" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="#e74c3c" CornerRadius="5" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#c0392b"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>
    </Grid>
</UserControl>
