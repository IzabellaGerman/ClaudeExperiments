<UserControl x:Class="ShoppingPlanner.MVVM.View.DeliveryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="10">
            <TextBlock Text="Delivery &amp; Schedule"
                       Foreground="White"
                       FontSize="22"
                       FontWeight="Bold"
                       Margin="0,0,0,5"/>
            <TextBlock Text="Configure delivery method and purchase schedule"
                       Foreground="#CFCFCF"
                       FontSize="13"
                       Margin="0,0,0,20"/>

            <!-- Delivery Method -->
            <Border Background="#22202f" CornerRadius="10" Padding="22" Margin="0,0,0,18">
                <StackPanel>
                    <TextBlock Text="Delivery Method"
                               Foreground="White"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Margin="0,0,0,15"/>

                    <RadioButton Content="Alfa Box (nearest pickup point)"
                                 IsChecked="{Binding IsAlfaBox}"
                                 Foreground="White"
                                 FontSize="14"
                                 Margin="5,6"
                                 GroupName="Delivery"/>

                    <RadioButton Content="Zásilkovna (Z-Point / Z-Box)"
                                 IsChecked="{Binding IsZasilkovna}"
                                 Foreground="White"
                                 FontSize="14"
                                 Margin="5,6"
                                 GroupName="Delivery"/>
                </StackPanel>
            </Border>

            <!-- Schedule -->
            <Border Background="#22202f" CornerRadius="10" Padding="22">
                <StackPanel>
                    <TextBlock Text="Purchase Schedule"
                               Foreground="White"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Margin="0,0,0,15"/>

                    <TextBlock Text="How often should purchases be made?"
                               Foreground="#CFCFCF" FontSize="13" Margin="0,0,0,5"/>
                    <ComboBox ItemsSource="{Binding ScheduleOptions}"
                              SelectedItem="{Binding SelectedSchedule}"
                              FontSize="13" Padding="8,6"
                              Width="260" HorizontalAlignment="Left"
                              Margin="0,0,0,18"/>

                    <TextBlock Text="Preferred day of the week"
                               Foreground="#CFCFCF" FontSize="13" Margin="0,0,0,5"/>
                    <ComboBox ItemsSource="{Binding DayOptions}"
                              SelectedItem="{Binding SelectedDay}"
                              FontSize="13" Padding="8,6"
                              Width="260" HorizontalAlignment="Left"
                              Margin="0,0,0,18"/>

                    <TextBlock Text="Next scheduled purchase"
                               Foreground="#CFCFCF" FontSize="13" Margin="0,0,0,5"/>
                    <DatePicker SelectedDate="{Binding NextPurchaseDate}"
                                FontSize="13"
                                Width="260" HorizontalAlignment="Left"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
