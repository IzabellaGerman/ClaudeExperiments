<UserControl x:Class="ShoppingPlanner.MVVM.View.StoresView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="10">
            <TextBlock Text="Select Your Stores"
                       Foreground="White"
                       FontSize="22"
                       FontWeight="Bold"
                       Margin="0,0,0,8"/>
            <TextBlock Text="Choose the stores you regularly shop at"
                       Foreground="#CFCFCF"
                       FontSize="13"
                       Margin="0,0,0,20"/>

            <Border Background="#22202f"
                    CornerRadius="10"
                    Padding="20">
                <ItemsControl ItemsSource="{Binding Stores}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <CheckBox Content="{Binding Name}"
                                      IsChecked="{Binding IsSelected}"
                                      Foreground="White"
                                      FontSize="14"
                                      Margin="5,7"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemContainerStyle>
                        <Style>
                            <Setter Property="FrameworkElement.MinWidth" Value="180"/>
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                </ItemsControl>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
