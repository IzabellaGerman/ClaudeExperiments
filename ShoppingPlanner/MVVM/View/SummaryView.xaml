<UserControl x:Class="ShoppingPlanner.MVVM.View.SummaryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="10">
            <TextBlock Text="Shopping Plan Summary"
                       Foreground="White"
                       FontSize="22"
                       FontWeight="Bold"
                       Margin="0,0,0,20"/>

            <!-- Stores -->
            <Border Background="#22202f" CornerRadius="10" Padding="18" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Selected Stores"
                               Foreground="White" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <TextBlock Text="{Binding SummaryStores}"
                               Foreground="#CFCFCF" FontSize="13" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- Products -->
            <Border Background="#22202f" CornerRadius="10" Padding="18" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Products"
                               Foreground="White" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <TextBlock Text="{Binding SummaryProducts}"
                               Foreground="#CFCFCF" FontSize="13" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- Delivery -->
            <Border Background="#22202f" CornerRadius="10" Padding="18" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Delivery &amp; Schedule"
                               Foreground="White" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <TextBlock Text="{Binding SummaryDelivery}"
                               Foreground="#CFCFCF" FontSize="13" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- Payment -->
            <Border Background="#22202f" CornerRadius="10" Padding="18" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Payment"
                               Foreground="White" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <TextBlock Text="{Binding SummaryPayment}"
                               Foreground="#CFCFCF" FontSize="13" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- Save / Load buttons -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                <Button Content="  Save Plan  "
                        Command="{Binding SaveCommand}"
                        Padding="16,8" Margin="0,0,10,0"
                        FontSize="13" Foreground="White" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="#27AE60" CornerRadius="5" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#219A52"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button Content="  Load Plan  "
                        Command="{Binding LoadCommand}"
                        Padding="16,8"
                        FontSize="13" Foreground="White" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="#3498DB" CornerRadius="5" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#2980B9"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
