<Window x:Class="ShoppingPlanner.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:viewModel="clr-namespace:ShoppingPlanner.MVVM.ViewModel"
        Height="700" Width="1050"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <viewModel:MainViewModel/>
    </Window.DataContext>

    <Border Background="#272537"
            CornerRadius="20">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="75"/>
                <RowDefinition/>
            </Grid.RowDefinitions>

            <!-- Title -->
            <TextBlock Text="Shopping Planner"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Left"
                       Foreground="White"
                       FontSize="18"
                       FontWeight="Bold"
                       Margin="25,0,0,0"
                       Grid.Column="0"
                       Grid.Row="0"/>

            <!-- Top Bar: Search + Window Controls -->
            <Grid Grid.Column="1" Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox Style="{StaticResource SearchBoxTheme}"
                         HorizontalAlignment="Left"
                         VerticalAlignment="Center"
                         Margin="15,0,0,0"/>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Top"
                            HorizontalAlignment="Right"
                            Margin="0,12,15,0">

                    <!-- Minimize Button -->
                    <Border x:Name="MinimizeBtn"
                            Width="24" Height="24"
                            CornerRadius="12"
                            Margin="0,0,8,0"
                            Cursor="Hand"
                            MouseDown="MinimizeButton_MouseDown">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#353540"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#f39c12"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="−"
                                   Foreground="White"
                                   FontSize="14"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Margin="0,-3,0,0"/>
                    </Border>

                    <!-- Close Button -->
                    <Border x:Name="CloseBtn"
                            Width="24" Height="24"
                            CornerRadius="12"
                            Cursor="Hand"
                            MouseDown="CloseButton_MouseDown">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#353540"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#e74c3c"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="✕"
                                   Foreground="White"
                                   FontSize="11"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Margin="0,-1,0,0"/>
                    </Border>
                </StackPanel>
            </Grid>

            <!-- Drag area -->
            <Border Grid.Column="1" Grid.Row="0"
                    Background="Transparent"
                    MouseDown="Border_MouseDown"
                    Panel.ZIndex="-1"/>

            <!-- Sidebar Navigation -->
            <StackPanel Grid.Column="0" Grid.Row="1"
                        Margin="0,20,0,0">

                <RadioButton Content="Stores"
                             Height="45"
                             Style="{StaticResource MenuButtonTheme}"
                             IsChecked="True"
                             Command="{Binding StoresViewCommand}"/>

                <RadioButton Content="Products"
                             Height="45"
                             Style="{StaticResource MenuButtonTheme}"
                             Command="{Binding ProductsViewCommand}"/>

                <RadioButton Content="Delivery"
                             Height="45"
                             Style="{StaticResource MenuButtonTheme}"
                             Command="{Binding DeliveryViewCommand}"/>

                <RadioButton Content="Payment"
                             Height="45"
                             Style="{StaticResource MenuButtonTheme}"
                             Command="{Binding PaymentViewCommand}"/>

                <RadioButton Content="Summary"
                             Height="45"
                             Style="{StaticResource MenuButtonTheme}"
                             Command="{Binding SummaryViewCommand}"/>
            </StackPanel>

            <!-- Content Area -->
            <ContentControl Grid.Column="1" Grid.Row="1"
                            Margin="15,10,15,15"
                            Content="{Binding CurrentView}"/>
        </Grid>
    </Border>
</Window>
